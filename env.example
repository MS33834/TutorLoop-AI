# PostgreSQL (uses the docker-compose service name)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/tutorloop

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis / ARQ task queue
REDIS_URL=redis://redis:6379

# FastAPI app
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:4173

# Security (must be >= 32 characters; generate a strong random key, e.g.
# `python -c "import secrets;print(secrets.token_urlsafe(48))"`. Do NOT use
# the placeholder below in production — the app will refuse to start.)
SECRET_KEY=replace-with-a-strong-random-key-of-at-least-32-chars
# Access tokens are short-lived; use the refresh token (30 days) for sessions.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database migrations (run `alembic upgrade head` on startup)
RUN_ALEMBIC_MIGRATIONS=true

# Video processing
FRAME_INTERVAL_SECONDS=5

# Recommendation strategy: mastery_gap | balanced
RECOMMEND_STRATEGY=mastery_gap

# BKT parameters
BKT_P_L0=0.3
BKT_P_T=0.3
BKT_P_G=0.2
BKT_P_S=0.1

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Cloud LLM providers (comma-separated lists of equal length)
LLM_API_KEYS=
LLM_BASE_URLS=
LLM_MODELS=

# Local fallback LLM
LOCAL_BASE_URL=http://localhost:8001/v1
LOCAL_MODEL=qwen3.5-4b

# Vision model (optional)
VLM_MODEL=qwen2.5-vl
VLM_BASE_URL=
VLM_API_KEY=

# ARQ worker tuning
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=600
ARQ_KEEP_RESULT=3600

# Error tracking (optional)
SENTRY_DSN=
