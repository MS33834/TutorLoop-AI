# Comma-separated cloud LLM configurations (must have same length)
LLM_API_KEYS=
LLM_BASE_URLS=
LLM_MODELS=

# Local fallback model
LOCAL_BASE_URL=http://localhost:8001/v1
LOCAL_MODEL=qwen3.5-4b

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tutorloop

# Graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Task queue (ARQ + Redis)
REDIS_URL=redis://localhost:6379

# App
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=uploads
FRAME_INTERVAL_SECONDS=5
# Comma-separated list of allowed frontend origins. Keep this consistent across
# all env.example files and deployment configs.
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:4173

# Security (must be >= 32 characters; generate a strong random key, e.g.
# `python -c "import secrets;print(secrets.token_urlsafe(48))"`. Do NOT use
# the placeholder below in production — the app will refuse to start.)
SECRET_KEY=replace-with-a-strong-random-key-of-at-least-32-chars
# Access tokens are short-lived; use the refresh token (30 days) for sessions.
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Set to true in production (HTTPS) so refresh-token cookies are only sent over
# secure transports. Leave false for local HTTP dev.
COOKIE_SECURE=false

# Database migrations (run `alembic upgrade head` on startup)
RUN_ALEMBIC_MIGRATIONS=false

# Recommendation strategy: mastery_gap | balanced
RECOMMEND_STRATEGY=mastery_gap

# BKT parameters
BKT_P_L0=0.3
BKT_P_T=0.3
BKT_P_G=0.2
BKT_P_S=0.1

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vision model (optional)
VLM_MODEL=qwen2.5-vl
VLM_BASE_URL=
VLM_API_KEY=

# ARQ worker tuning
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=600
ARQ_KEEP_RESULT=3600

# Screenshot temp file cleanup: screenshots older than this many days are purged
# by the worker's periodic cleanup job (see app/tasks/jobs.py).
SCREENSHOT_RETENTION_DAYS=7

# Error tracking (optional)
SENTRY_DSN=
